# Only include infra/ and root docs in the repo
*
!.gitignore
!README.md
!infra/
!infra/**
!validation-tests/
!validation-tests/**
!aihub-compass-setup/
!aihub-compass-setup/**

# Python
validation-tests/3-dataplane-app/.venv/
validation-tests/3-dataplane-app/__pycache__/
validation-tests/3-dataplane-app/checks/__pycache__/

# Design doc (kept locally, not in repo)
design-doc.md

# Reference repos (cloned locally for analysis, not in repo)
references/

# Compiled ARM templates (generated from .bicep via `az bicep build`)
infra/**/*.json
!infra/bicep/bicepconfig.json

# Terraform state and providers (never commit)
infra/tf/.terraform/
infra/tf/*.tfstate
infra/tf/*.tfstate.backup
infra/tf/.terraform.lock.hcl

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Bicep cache
.bicep/
