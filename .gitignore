# Only include infra/ and root docs in the repo
*
!.gitignore
!README.md
!infra/
!infra/**
!app/
!app/**

# Python
app/.venv/
app/__pycache__/
app/checks/__pycache__/

# Design doc (kept locally, not in repo)
design-doc.md

# Reference repos (cloned locally for analysis, not in repo)
references/

# Compiled ARM templates (generated from .bicep via `az bicep build`)
infra/**/*.json
!infra/bicep/bicepconfig.json

# Terraform state and providers (never commit)
infra/tf/.terraform/
infra/tf/*.tfstate
infra/tf/*.tfstate.backup
infra/tf/.terraform.lock.hcl

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Bicep cache
.bicep/
