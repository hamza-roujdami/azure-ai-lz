<policies>
    <inbound>
        <base />
        <return-response>
            <set-status code="200" reason="OK" />
            <set-header name="Content-Type" exists-action="override">
                <value>application/json</value>
            </set-header>
            <set-body>@{
                var name = context.Request.MatchedParameters["deploymentName"];
                return "{\"name\": \"" + name + "\", \"properties\": {\"model\": {\"format\": \"OpenAI\", \"name\": \"" + name + "\", \"version\": \"\"}}}";
            }</set-body>
        </return-response>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
