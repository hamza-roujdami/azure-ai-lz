# Environment Configuration
# Copy this file to .env and update the values

# Azure AI Foundry Project
AZURE_AI_PROJECT_ENDPOINT=https://ai-csd-dev-uaen-001.services.ai.azure.com/api/projects/proj-csd-default-dev-uaen-001

# Connection and Model
AZURE_AI_CONNECTION_NAME=compass-apim
AZURE_AI_MODEL_NAME=gpt-5.1

# Agent (for chat_with_agent.py)
AZURE_AI_AGENT_NAME=compass-test-agent

# Authentication: Uses DefaultAzureCredential which picks up your 'az login' session.
